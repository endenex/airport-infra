# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI mode
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Authenticated data sources (all free, registration required) ──────────────
COMPANIES_HOUSE_API_KEY=
EDINET_SUBSCRIPTION_KEY=

# ── Document storage (Cloudflare R2) ─────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=airport-infra-documents
# R2 endpoint: https://<account_id>.r2.cloudflarestorage.com

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── LLM pipeline tuning (optional overrides) ─────────────────────────────────
# Model for bulk extraction (cost-efficient)
LLM_EXTRACTION_MODEL=claude-haiku-4-5-20251001
# Model for complex extraction and IC paper generation
LLM_COMPLEX_MODEL=claude-sonnet-4-6
# Confidence threshold above which records auto-populate (below = review queue)
LLM_HIGH_CONFIDENCE_THRESHOLD=0.85
